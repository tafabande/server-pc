# MediaHub Configuration

# Security (REQUIRED in production)
# Leave blank to auto-generate (sessions will reset on restart)
# For production: use a long random string (32+ chars)
SECRET_KEY=your-super-secret-long-string-change-this-in-production

# Database
# SQLite for development (default)
DATABASE_URL=sqlite+aiosqlite:///./mediahub.db
# For PostgreSQL production:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/mediahub

# Redis (optional, uses memory fallback if unavailable)
REDIS_URL=redis://localhost:6379/0

# Media
SHARED_FOLDER=./shared_media
MAX_UPLOAD_MB=500
ENABLE_HLS_TRANSCODING=true
HLS_CACHE_MAX_AGE_DAYS=7

# Streaming
DEFAULT_STREAM_QUALITY=medium  # low, medium, high
MAX_CONCURRENT_STREAMS=3
JPEG_QUALITY=75
STREAM_WIDTH=1280
STREAM_HEIGHT=720
STREAM_FPS=30

# Performance
THUMBNAIL_GENERATION=async  # sync, async
THUMBNAIL_WORKER_THREADS=2

# Development
DEBUG=false
LOG_LEVEL=INFO

# Network (LAN server settings)
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# Account Management
ENABLE_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false
PASSWORD_RESET_TOKEN_HOURS=1

# Admin Credentials (seed user on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_use_a_strong_password

# JWT Configuration
JWT_EXPIRE_HOURS=24
ALGORITHM=HS256

# RBAC - Guest access restriction
# Confine guest role to this subfolder (leave blank for no restriction)
GUEST_ROOT_PATH=

# Service Discovery
SERVICE_NAME=MediaHub

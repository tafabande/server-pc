# StreamDrop — Environment Configuration Example
# Copy to .env and fill in your values.

# ── Paths ──────────────────────────────────────────────
# Absolute path to the folder you want to share. Defaults to cwd.
# SHARED_FOLDER=C:\Users\User\Videos

# HLS transcode cache — MUST be outside SHARED_FOLDER for Docker read-only safety.
# TRANSCODE_DIR=C:\Users\User\Desktop\server\.cache\transcodes

# ── Network ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Admin Credentials (replaces PIN for RBAC) ─────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_use_a_strong_password

# ── JWT ────────────────────────────────────────────────
# Leave blank to auto-generate on startup (dev only — sessions break on restart).
# In production/Docker, set a stable secret:
# JWT_SECRET=your-super-secret-key-at-least-32-chars
JWT_EXPIRE_HOURS=24

# ── Database ───────────────────────────────────────────
# Dev default: SQLite (no extra setup needed)
# DATABASE_URL=sqlite+aiosqlite:///.data/streamdrop.db
# Production (Docker):
# DATABASE_URL=postgresql+asyncpg://streamdrop:streamdrop@postgres:5432/streamdrop

# ── Redis ──────────────────────────────────────────────
# Dev: leave unset (falls back to in-memory — sessions lost on restart)
# Production (Docker):
# REDIS_URL=redis://redis:6379/0

# ── RBAC ───────────────────────────────────────────────
# Guests are restricted to this subfolder. Leave blank for no restriction.
# GUEST_ROOT_PATH=kids_movies

# ── Streaming ──────────────────────────────────────────
JPEG_QUALITY=75
STREAM_WIDTH=1280
STREAM_HEIGHT=720
STREAM_FPS=30

# ── Uploads ────────────────────────────────────────────
MAX_UPLOAD_MB=500

# ── Service Discovery ─────────────────────────────────
SERVICE_NAME=StreamDrop
